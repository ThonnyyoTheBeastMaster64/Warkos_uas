<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        SECURITY FIXES:
        - allowBackup changed to "false": with it "true", `adb backup` (or
          cloud auto-backup) could copy this app's private data off the
          device without root, including anything cached from login/order
          flows. Turned off since this app has no legitimate need for it.
        - usesCleartextTraffic removed in favor of networkSecurityConfig,
          which allows plaintext HTTP only for the specific dev hosts
          listed in network_security_config.xml instead of everywhere.
    -->
    <application
        android:allowBackup="false"
        android:label="Pesanan Makanan"
        android:theme="@style/Theme.PesananMakanan"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".AdminMainActivity" android:exported="false" />
        <activity android:name=".ProdukFormActivity" android:exported="false" />
        <activity android:name=".DashboardActivity" android:exported="false" />
        <activity android:name=".KasirActivity" android:exported="false" />
        <activity android:name=".VerifikasiEmailActivity" android:exported="false" />
        <activity android:name=".RegisterActivity" android:exported="false" />
        <activity android:name=".PenggunaActivity" android:exported="false" />

    </application>
</manifest>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:background="@drawable/bg_screen_gradient">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrasi Akun"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark"
        android:layout_marginBottom="30dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_glass_panel">

            <!-- Bagian 1: Input Data (Awal) -->
            <LinearLayout
                android:id="@+id/layoutInputData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/etRegEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email Aktif"
                    android:inputType="textEmailAddress"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_field_glossy"/>

                <EditText
                    android:id="@+id/etRegPass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password Baru"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_field_glossy"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih Role:"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"
                    android:textColor="@color/grey"/>

                <Spinner
                    android:id="@+id/spinnerRole"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_field_glossy"
                    android:padding="10dp" />

                <EditText
                    android:id="@+id/etSecretCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Kode Rahasia (Khusus Admin/Kasir)"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone"
                    android:background="@drawable/bg_field_glossy"/>

                <Button
                    android:id="@+id/btnDoRegister"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="DAFTAR SEKARANG"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <!-- Bagian 2: Input OTP (Hidden by default) -->
            <LinearLayout
                android:id="@+id/layoutInputOtp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Masukkan kode OTP yang dikirim ke email anda:"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/etRegOtp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="6 Digit Kode OTP"
                    android:inputType="number"
                    android:maxLength="6"
                    android:gravity="center"
                    android:padding="14dp"
                    android:textSize="20sp"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_field_glossy"/>

                <Button
                    android:id="@+id/btnVerifyReg"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="VERIFIKASI &amp; SELESAI"
                    android:textStyle="bold"
                    android:backgroundTint="@color/accent_green"
                    android:textColor="@color/white"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressReg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnBackLogin"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Batal, Kembali ke Login"
        android:layout_marginTop="20dp"
        android:textColor="@color/primary"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Form Produk"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_glass_panel"
            android:elevation="4dp">

            <EditText
                android:id="@+id/etNamaProduk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nama Produk"
                android:padding="14dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_field_glossy"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Kategori:"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp"/>

            <Spinner
                android:id="@+id/spKategori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_field_glossy"/>

            <EditText
                android:id="@+id/etHarga"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Harga (Rp)"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_field_glossy"/>

            <EditText
                android:id="@+id/etStok"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Stok"
                android:inputType="number"
                android:padding="14dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_field_glossy"/>

            <com.android.volley.toolbox.NetworkImageView
                android:id="@+id/ivPreviewLama"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_thumb_glass"
                android:layout_marginBottom="10dp"/>

            <ImageView
                android:id="@+id/ivPreviewBaru"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_thumb_glass"
                android:visibility="gone"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnPilihGambar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Pilih Gambar (JPG/PNG)"
                android:textAllCaps="false"
                android:background="@drawable/btn_glossy_grey"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnSimpanProduk"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Simpan Produk"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/btn_glossy_primary"
                android:textColor="@color/white"/>

            <ProgressBar
                android:id="@+id/progressForm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary"
                android:layout_marginTop="14dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

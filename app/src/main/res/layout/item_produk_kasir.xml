<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="7dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/glass_white"
    app:strokeColor="@color/glass_border_blue"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <com.android.volley.toolbox.NetworkImageView
            android:id="@+id/ivGambarKasir"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_thumb_glass"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaProdukKasir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/tvKategoriKasir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/grey"/>

            <TextView
                android:id="@+id/tvHargaStokKasir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/primary_dark"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnKurang"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:text="-"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="@drawable/btn_glossy_grey"
            android:textColor="@color/white"
            android:padding="0dp"/>

        <TextView
            android:id="@+id/tvQty"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/black"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnTambah"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:text="+"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="@drawable/btn_glossy_primary"
            android:textColor="@color/white"
            android:padding="0dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

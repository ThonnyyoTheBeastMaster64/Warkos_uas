<?xml version="1.0" encoding="utf-8"?>
<!--
    SECURITY FIX: the app previously set android:usesCleartextTraffic="true"
    globally, which allows plaintext HTTP to ANY host, including whatever
    Wi-Fi/captive portal or malicious network the phone might join. That
    means login credentials and order/address data could be sent unencrypted
    to an attacker on the same network (classic MITM risk).

    This config instead allows cleartext ONLY for the specific local dev
    addresses used while testing against XAMPP/emulator, per ApiConfig.java.
    Everything else on the device must use HTTPS.

    Before shipping to production: point ApiConfig.BASE_URL at a real HTTPS
    server and delete the cleartext domain-config block below entirely.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator's special alias for the host machine's localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Loopback, in case testing directly on a device with adb reverse -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">192.168.0.105</domain>
        <!-- If testing on a physical phone over Wi-Fi (not the emulator),
             add your dev machine's actual LAN IP here, e.g.:
             <domain includeSubdomains="false">192.168.1.5</domain>
             Note: Android's network-security-config only accepts exact
             hostnames/IPs, not CIDR ranges, so each dev IP must be listed
             individually and removed again once no longer needed. -->
    </domain-config>

    <base-config cleartextTrafficPermitted="false" />
</network-security-config>

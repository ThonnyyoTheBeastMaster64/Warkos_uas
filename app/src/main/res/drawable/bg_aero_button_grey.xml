<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <gradient
                android:angle="90"
                android:startColor="#EAF3F7"
                android:centerColor="#C6DCE6"
                android:endColor="#9FBCC9"
                android:type="linear"/>
            <stroke android:width="1dp" android:color="#9FBCC9"/>
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp"/>
            <gradient
                android:angle="90"
                android:startColor="#B3FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>

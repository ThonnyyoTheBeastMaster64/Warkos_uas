<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <gradient
                android:angle="90"
                android:startColor="@color/accent_green_dark"
                android:endColor="#3D9459"
                android:type="linear"/>
        </shape>
    </item>
    <item
        android:top="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp"/>
            <gradient
                android:angle="90"
                android:startColor="#66FFFFFF"
                android:endColor="@color/sheen_bottom"
                android:type="linear"
                android:centerY="0.35"/>
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- base glossy blue pill -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <gradient
                android:angle="90"
                android:startColor="#7FD4F0"
                android:centerColor="#1E90D8"
                android:endColor="#0B5FA5"
                android:type="linear"/>
            <stroke android:width="1dp" android:color="#0B5FA5"/>
        </shape>
    </item>
    <!-- glass highlight on top half -->
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp"/>
            <gradient
                android:angle="90"
                android:startColor="#B3FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
